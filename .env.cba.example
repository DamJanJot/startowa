# Optivio - przykladowa konfiguracja dla hostingu CBA
# Skopiuj ten plik do .env i uzupelnij wartosci z panelu CBA

DB_HOST=localhost
DB_NAME=twoja_baza
DB_USER=twoj_uzytkownik_bazy
DB_PASS=twoje_haslo_bazy

# Ustawienia maila (opcjonalnie, jesli uzywasz modułu kalendarza/powiadomien)
MAIL_HOST=smtp.twojadomena.pl
MAIL_PORT=587
MAIL_USERNAME=twoj_mail@twojadomena.pl
MAIL_PASSWORD=twoje_haslo_mail
MAIL_FROM=twoj_mail@twojadomena.pl
MAIL_FROM_NAME=Optivio
